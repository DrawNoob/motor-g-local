<style>
  .swiper-pagination-{{ section.id }} .swiper-pagination-bullet {
    border: 1px solid #8B97A1;
    width: 8px;
    height: 8px;
    cursor: pointer;
  }
</style>

<div class="lg:pl-[30px]">
  <div class="swiper-{{ section.id }} flex items-center max-w-[1440px] mx-auto">
    <div class="swiper-wrapper flex">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product %}
          <a href="{{ product.url }}" class="swiper-slide py-4 px-6 flex items-center gap-5 bg-white">
            <img
              class="object-cover w-[90px] h-[90px]"
              src="{{ product.featured_image | image_url: width: 180 }}"
              alt="{{ product.title | escape }}"
            >
            <div class="flex flex-col gap-2">
              <p class="font-neue-m">{{ product.title }}</p>
              <p class="font-neue-r">{{ product.price | money }}</p>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
  <div class="swiper-pagination-{{ section.id }} w-max flex items-center gap-[10px] h-[20px] mt-2"></div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function init() {
      const el = document.querySelector('.swiper-{{ section.id }}');
      if (!el) return;

      if (el.swiper) el.swiper.destroy(true, true);

      new Swiper(el, {
        direction: 'horizontal',
        loop: false,
        centeredSlides: false,
        speed: 1000,
        slidesPerView: 2,
        spaceBetween: 20,
        pagination: {
          el: '.swiper-pagination-{{ section.id }}',
          clickable: true,
        },
        breakpoints: {
          320: {
            slidesPerView: 1.5,
            spaceBetween: 20,
          },
          640: {
            slidesPerView: 1.1,
            spaceBetween: 20,
          },
          1100: {
            slidesPerView: 1.5,
            spaceBetween: 20,
          },
          1400: {
            slidesPerView: 1.9,
            spaceBetween: 20,
          },
        },
      });
    }

    init();

    document.addEventListener('shopify:section:load', function (e) {
      if (e.target.querySelector('.swiper-{{ section.id }}')) {
        init();
      }
    });
  });
</script>
