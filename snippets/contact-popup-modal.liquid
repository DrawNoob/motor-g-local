<div id="support-modal" class="fixed inset-0 z-50 bg-black/60 hidden flex items-center justify-center">
  <div class="modal-bg absolute inset-0"></div>
  <div class="bg-white rounded-lg shadow-xl w-full max-w-md mx-4 relative z-10">
    <div class="flex w-full justify-between items-center">
      <h3 class="text-xl font-bold px-6 pt-6">{{ section.settings.modal_title }}</h3>
      <button class="modal-close px-6 pt-6 text-gray-500 hover:text-black cursor-pointer font-bold text-2xl">×</button>
    </div>
    <div>
      <div>
        <iframe
          src="{{ section.settings.highlevel_embed_url }}"
          style="width:100%;height:100%;border:none;border-radius:3px"
          id="inline-hNc1ZX2ConTMLlSIS795"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="01_Motor-G_website_contact_form_EN"
          data-height="521"
          data-layout-iframe-id="inline-hNc1ZX2ConTMLlSIS795"
          data-form-id="hNc1ZX2ConTMLlSIS795"
          title="01_Motor-G_website_contact_form_EN"
        >
        </iframe>
        <script src="https://link.msgsndr.com/js/form_embed.js" async></script>
      </div>
    </div>
  </div>
</div>

{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    const openButtons = document.querySelectorAll('.support-modal-btn');
    const modal = document.getElementById('support-modal');
    const closeBtn = modal.querySelector('.modal-close');
    const modalBg = modal.querySelector('.modal-bg');

    openButtons.forEach((btn) => {
      btn.addEventListener('click', function () {
        modal.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
      });
    });

    function closeModal() {
      modal.classList.add('hidden');
      document.body.classList.remove('overflow-hidden');
    }

    closeBtn?.addEventListener('click', closeModal);
    modalBg?.addEventListener('click', closeModal);
  });
{% endjavascript %}
