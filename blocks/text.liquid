<style>
  @media (max-width: 768px) {
    .text-max-width {
      width: 100% !important;
    }
  }
</style>
<div
  style="
    color: {{ block.settings.text_color }};
    width: {{ block.settings.max_width }}%;
  "
  class="
    text-block mx-auto text-max-width
    text-{{ block.settings.alignment }}
    pt-{{ block.settings.padding_top }} pb-{{ block.settings.padding_bottom }}
    md:text-{{ block.settings.font_size }} text-{{ block.settings.font_size_mob }}
    {% if block.settings.mobile_text %} md:hidden {% endif %}
    {% if block.settings.desktop_text %} md:block hidden {% endif %}
    font-{{ block.settings.font }}
  "
>
  {{ block.settings.text }}
</div>

{% schema %}
{
  "name": "Text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "font",
      "label": "Custom Font",
      "options": [
        { "value": "emilio", "label": "Emilio" },
        { "value": "neue-l", "label": "Neue - Light" },
        { "value": "neue-r", "label": "Neue - Roman" },
        { "value": "neue-m", "label": "Neue - Medium" },
        { "value": "neue-b", "label": "Neue - Black" }
      ]
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "FontSize",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "base", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "2xl", "label": "2XL" },
        { "value": "3xl", "label": "3XL" },
        { "value": "4xl", "label": "4XL" },
        { "value": "5xl", "label": "5XL" }
      ],
      "default": "2xl"
    },
    {
      "type": "select",
      "id": "font_size_mob",
      "label": "FontSize Mob",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "base", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "2xl", "label": "2XL" },
        { "value": "3xl", "label": "3XL" },
        { "value": "4xl", "label": "4XL" },
        { "value": "5xl", "label": "5XL" }
      ],
      "default": "base"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "Alignment",
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Top padding",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "4", "label": "Small" },
        { "value": "8", "label": "Medium" },
        { "value": "12", "label": "Large" },
        { "value": "16", "label": "Extra Large" }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "4", "label": "Small" },
        { "value": "8", "label": "Medium" },
        { "value": "12", "label": "Large" },
        { "value": "16", "label": "Extra Large" }
      ],
      "default": "0"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Max width",
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "desktop_text",
      "label": "Only Desktop Visible",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "mobile_text",
      "label": "Only Mobile Visible",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Text Content",
      "settings": {
        "text": "<p>Hello, world!</p>"
      }
    }
  ]
}
{% endschema %}
