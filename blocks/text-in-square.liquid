<div
  style="
    color: {{ block.settings.text_color }};
    background-color: {{ block.settings.bg_color }}
  "
  class="
    text-block font-{{ block.settings.font_family }} text-{{ block.settings.alignment }} text-{{ block.settings.font_size }}
    pt-{{ block.settings.padding_top }} pb-{{ block.settings.padding_bottom }} px-5 py-2
  "
>
  {{ block.settings.text }}
</div>

{% schema %}
{
  "name": "Text in Square",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family",
      "options": [
        { "value": "filson-light", "label": "Filson Light" },
        { "value": "filson-reg", "label": "Filson Regular" },
        { "value": "filson-bold", "label": "Filson Bold" },
        { "value": "robot-thin", "label": "Robot Think" },
        { "value": "robot-light", "label": "Robot Light" },
        { "value": "robot-reg", "label": "Robot Regular" },
        { "value": "robot-med", "label": "Robot Medium" },
        { "value": "robot-bold", "label": "Robot Bold" },
        { "value": "robot-black", "label": "Robot Black" },
        { "value": "din", "label": "Din" }
      ],
      "default": "filson-reg"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "Font size",
      "options": [
        { "value": "sm", "label": "Small" },
        { "value": "base", "label": "Medium" },
        { "value": "lg", "label": "Large" },
        { "value": "xl", "label": "Extra Large" },
        { "value": "2xl", "label": "2XL" },
        { "value": "3xl", "label": "3XL" },
        { "value": "4xl", "label": "4XL" },
        { "value": "5xl", "label": "5XL" }
      ],
      "default": "2xl"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "Alignment",
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "select",
      "id": "padding_top",
      "label": "Top padding",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "4", "label": "Small" },
        { "value": "8", "label": "Medium" },
        { "value": "12", "label": "Large" },
        { "value": "16", "label": "Extra Large" }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "options": [
        { "value": "0", "label": "None" },
        { "value": "4", "label": "Small" },
        { "value": "8", "label": "Medium" },
        { "value": "12", "label": "Large" },
        { "value": "16", "label": "Extra Large" }
      ],
      "default": "0"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Square Color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Text in Square",
      "settings": {
        "text": "<p>Hello, world!</p>"
      }
    }
  ]
}
{% endschema %}
