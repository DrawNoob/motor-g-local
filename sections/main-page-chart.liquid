<section class="responsive-padding bg-background md:pb-[70px] pb-[50px]">
  <div class=" max-w-[1440px] mx-auto flex flex-col">
    <div class="w-full md:pt-10">
      <!-- Google Chart -->
      <div class="w-full flex flex-col-reverse md:flex-row gap-6 md:mt-10">
        <!-- Графік -->
        <div class="w-full lg:w-9/12 md:w-8/12 bg-white p-4 rounded shadow relative">
          <div
            id="thrust-chart"
            class="w-full h-[400px]"
            data-chart="{{ section.settings.chart_data | strip_newlines | escape }}"
          ></div>

          <img src="{{ 'drone-icon.webp' | asset_url }}" alt="Drone" class="absolute top-4 lg:right-20 right-10 w-[80px] md:w-[100px]">
        </div>

        <!-- Легенда / правий блок -->
        <div class="w-full lg:w-3/12 md:w-4/12 bg-white px-[30px] lg:py-[50px] py-5 rounded shadow">
          <div class="flex items-center gap-2 mb-2 border-b-2 pb-4">
            <img src="{{ 'propeler-chart.webp' |asset_url }}" alt="Propeler">
            <h3 class="font-semibold">{{ section.settings.propeler_title }}</h3>
          </div>
          <!-- Динамічна легенда -->
          <div class="dynamic-legend mt-4"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const script = document.createElement('script');
  script.src = 'https://www.gstatic.com/charts/loader.js';
  script.defer = true;
  script.onload = () => {
    google.charts.load('current', { packages: ['corechart'] });
    google.charts.setOnLoadCallback(initializeChart);
  };
  document.head.appendChild(script);

  function initializeChart() {
    const chartElement = document.getElementById('thrust-chart');
    const rawData = chartElement.getAttribute('data-chart');
    const parsedData = JSON.parse(rawData); // ✅ тепер це справжній JSON

    const data = google.visualization.arrayToDataTable(parsedData);

    const options = {
      curveType: 'function',
      legend: 'none',
      colors: ['#0026E7', '#777', '#2ecc71', '#ec7063', '#9b59b6', '#f4d03f'],
      pointsVisible: true,
      pointSize: 6,
      hAxis: {
        title: 'Throttle, % (ESC)',
        textStyle: { fontSize: 12 },
        titleTextStyle: { fontSize: 14, bold: true },
      },
      vAxis: {
        title: 'Thrust, gf',
        viewWindow: {
          min: {{ section.settings.min_value | default: 1500 }},
          max: {{ section.settings.max_value | default: 3300 }}
        },
        textStyle: { fontSize: 12 },
        titleTextStyle: { fontSize: 14, bold: true },
        gridlines: { count: 10, color: '#E0E0E0' },
        minorGridlines: { count: 0 },
      },
      chartArea: {
        left: 80,
        right: 20,
        bottom: 60,
        top: 30,
        width: '80%',
        height: '80%',
      },
    };

    const chart = new google.visualization.LineChart(chartElement);
    chart.draw(data, options);
    window.addEventListener('resize', () => chart.draw(data, options));



    // Автоматичне виведення легенди
    const legendContainer = document.querySelector('.dynamic-legend');

    if (legendContainer) {
      const headers = data.getNumberOfColumns(); 
      const colors = options.colors;
      const labels = [];

      for (let i = 1; i < headers; i++) { 
        const name = data.getColumnLabel(i);
        const color = colors[i - 1] || '#000';
        labels.push(`<li class="flex items-center gap-2 text-sm font-neue-m">
          <span class="w-3 h-3 rounded-full" style="background:${color}"></span> ${name}
        </li>`);
      }

      legendContainer.innerHTML = `<ul class="mt-4 space-y-2">${labels.join('')}</ul>`;
    }

  }
</script>

{% schema %}
{
  "name": "Thrust Chart",
  "settings": [
    {
      "type": "header",
      "content": "Chart Y Axis Settings"
    },
    {
      "type": "number",
      "id": "min_value",
      "label": "Y Axis Min Value (Thrust)",
      "default": 1500
    },
    {
      "type": "number",
      "id": "max_value",
      "label": "Y Axis Max Value (Thrust)",
      "default": 3300
    },
    {
      "type": "header",
      "content": "Chart Data"
    },
    {
      "type": "textarea",
      "id": "chart_data",
      "label": "Add Chart Data (JSON format)",
      "default": "[\n  [\"Throttle, % (ESC)\", \"Motor-G 900KV\", \"Xing 31 10 900KV\"],\n  [\"70%\", 1900, 1850],\n  [\"80%\", 2300, 2200],\n  [\"90%\", 2700, 2550],\n  [\"100%\", 3100, 2850]\n]"
    },
    {
      "type": "text",
      "id": "propeler_title",
      "label": "Propeler Title",
      "default": "Пропелер 1045"
    }
  ],
  "presets": [
    {
      "name": "Thrust Chart"
    }
  ]
}
{% endschema %}
