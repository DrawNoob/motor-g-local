<!-- Map -->
<section class="md:pt-[70px] pt-5 bg-background {% unless template == 'page.contact' %} pb-20 {% endunless %}">
  <div class="max-w-[1440px] mx-auto responsive-padding md:min-h-[500px]">
    <h1 class="md:text-3xl text-2xl font-neue-m">{{ section.settings.heading }}</h1>
    <div class="flex md:flex-row flex-col md:mt-10 mt-6">
      <div class="md:w-1/2 w-full">
        <!-- Map -->
        <div class="mapouter md:w-11/12 w-full">
          <div class="gmap_canvas w-full md:h-[500px] h-[200px]">
            <iframe
              class="gmap_iframe"
              width="100%"
              height="100%"
              frameborder="0"
              scrolling="no"
              marginheight="0"
              marginwidth="0"
              src="{{ section.settings.map_url }}"
            >
            </iframe>
          </div>
        </div>
      </div>
      <div class="md:w-1/2 w-full flex flex-col justify-around">
        <!-- Email -->
        <div class="flex flex-col gap-2 justify-center lg:px-[50px] md:px-5 px-0 md:py-0 pt-10 md:h-1/3 border-b-[1px] border-light-gray">
          <p>{{ 'customer.login_page.email' | t }}</p>
          <a class="flex items-center gap-2 lg:text-3xl sm:text-2xl text-xl font-neue-m" href="mailto:{{ section.settings.email }}">
            {{ section.settings.email }}
            <img src="{{ 'blue-arr.svg' | asset_url }}" alt="Email Arrow">
          </a>
        </div>

        <!-- Phone -->
        <div class="flex flex-col gap-2 justify-center lg:px-[50px] md:px-5 px-0 md:py-0 pt-10 md:h-1/3 border-b-[1px] border-light-gray">
          <p>{{ 'customer.addresses.phone' | t }}</p>
          <a class="flex items-center gap-2 lg:text-3xl sm:text-2xl text-xl font-neue-m" href="tel:{{ section.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' }}">
            {{ section.settings.phone }}
            <img src="{{ 'blue-arr.svg' | asset_url }}" alt="Phone Arrow">
          </a>
        </div>

        <!-- Messengers -->
        <div class="flex flex-col gap-6 justify-center lg:px-[50px] md:px-5 px-0 md:py-0 pt-10 md:h-1/3">
          <p>{{ 'customer.order.messangers' | t }}</p>
          <div class="flex gap-5 items-center">
            <a class="flex items-center gap-2 lg:text-3xl sm:text-2xl text-xl font-neue-m" href="{{ section.settings.viber_link }}">
              {{ section.settings.viber_title }}
              <img src="{{ 'blue-arr.svg' | asset_url }}" alt="Viber">
            </a>

            <a class="flex items-center gap-2 lg:text-3xl sm:text-2xl text-xl font-neue-m" href="{{ section.settings.signal_link }}">
              {{ section.settings.signal_title }}
              <img src="{{ 'blue-arr.svg' | asset_url }}" alt="Signal">
            </a>

            <a class="flex items-center gap-2 lg:text-3xl sm:text-2xl text-xl font-neue-m" href="{{ section.settings.whatsapp_link }}">
              {{ section.settings.whatsapp_title }}
              <img src="{{ 'blue-arr.svg' | asset_url }}" alt="WhatsApp">
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contacts",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Заголовок",
      "default": "Наші контакти:"
    },
    {
      "type": "header",
      "content": "Map Content"
    },
    {
      "type": "url",
      "id": "map_url",
      "label": "Map Location"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "info@motor-g.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Телефон",
      "default": "+38 (063) 941-31-10"
    },
    {
      "type": "header",
      "content": "Viber"
    },
    {
      "type": "text",
      "id": "viber_title",
      "label": "Назва Viber",
      "default": "Viber"
    },
    {
      "type": "url",
      "id": "viber_link",
      "label": "Посилання Viber"
    },
    {
      "type": "header",
      "content": "Signal"
    },
    {
      "type": "text",
      "id": "signal_title",
      "label": "Назва Signal",
      "default": "Signal"
    },
    {
      "type": "url",
      "id": "signal_link",
      "label": "Посилання Signal"
    },
    {
      "type": "header",
      "content": "WhatsApp"
    },
    {
      "type": "text",
      "id": "whatsapp_title",
      "label": "Назва WhatsApp",
      "default": "WhatsApp"
    },
    {
      "type": "url",
      "id": "whatsapp_link",
      "label": "Посилання WhatsApp"
    }
  ],
  "presets": [
    {
      "name": "Contacts"
    }
  ]
}
{% endschema %}
