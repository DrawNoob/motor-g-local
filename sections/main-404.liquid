<!-- TODO: Add Bacground Image with 404 -->
<div
  class="flex flex-col justify-center items-center bg-background h-[75vh] gap-8"
>
  {% if section.settings.image %}
    <img
      style="width: {{ section.settings.image_width }};"
      src="{{ section.settings.image | image_url }}"
      alt="404 Logo"
    >
  {% endif %}
  <h1 class="text-2xl md:text-5xl font-emilio">{{ 'templates.404.title' | t }}</h1>
  <a href="/">
    <button class="w-[300px] h-[65px] flex items-center justify-center font-neue-r cursor-pointer">
      {{ 'general.continue_shopping' | t }}
    </button>
  </a>
</div>

{% schema %}
{
  "name": "404 Page",
  "settings": [
    {
      "type": "header",
      "content": "Image Customize"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Logo in the Middle"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Image Width",
      "min": 5,
      "max": 250,
      "step": 5,
      "default": 40,
      "info": "Width of image in the middle"
    }
  ]
}
{% endschema %}
