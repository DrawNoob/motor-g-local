<section class="password-page bg-background flex flex-col items-center justify-center min-h-screen responsive-padding">
  <div class="max-w-[1440px] mx-auto w-full flex flex-col items-center">
    <div class="mb-8">
      <a href="{{ routes.root_url }}" class="logo">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" class="max-w-[200px]">
        {% else %}
          <img src="{{ 'header-logo.webp' | asset_url }}" alt="{{ shop.name }}" class="max-w-[200px]">
        {% endif %}
      </a>
    </div>

    <div class="text-center mb-12">
      <h1 class="xl:text-[55px] lg:text-[40px] text-3xl font-neue-m mb-4">{{ section.settings.heading }}</h1>
      <div class="font-neue-r text-xl">{{ section.settings.subtext }}</div>
    </div>

    <div class="w-full max-w-md bg-white p-8 rounded-lg shadow-lg">
      {% form 'storefront_password' %}
        {% if form.errors %}
          <div class="text-red-500 text-sm mb-4">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="mb-6">
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">{{ 'general.password_page.login_form_password_label' | t }}</label>
          <input
            type="password"
            name="password"
            id="password"
            class="w-full border-b-[1px] border-gray-500 py-4 focus:pl-4"
            placeholder="{{ section.settings.password_placeholder }}"
          >
        </div>

        <button
          type="submit"
          class="w-full bg-main-blue text-white py-4 rounded-lg font-neue-m hover:bg-opacity-90 transition-all duration-200"
        >
          {{ section.settings.button_text }}
        </button>
      {% endform %}
    </div>

    <div class="mt-8 text-center">
      <p class="text-sm text-gray-600 mb-2">{{ 'general.password_page.admin_link_html' | t }}</p>
      <a href="/admin" class="text-main-blue hover:underline font-neue-m">{{ section.settings.login_text }}</a>
    </div>

    <div class="mt-12 text-center text-sm text-gray-500">
      <p>
        © {{ 'now' | date: '%Y' }}
        {{ shop.name }}.
      </p>

      {% if section.settings.show_social_icons and section.settings.social_links != blank %}
        <div class="mt-4 flex justify-center space-x-4">
          {% for link in linklists[section.settings.social_links].links %}
            <a href="{{ link.url }}" class="text-main-blue hover:text-opacity-80 transition-all">
              {{ link.title }}
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Password Page",
  "settings": [
    {
      "type": "header",
      "content": "Branding"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Скоро відкриття"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Наш магазин незабаром відкриється. Будьте першими, хто дізнається про запуск!</p>"
    },
    {
      "type": "text",
      "id": "password_placeholder",
      "label": "Password placeholder",
      "default": "Введіть пароль"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Увійти"
    },
    {
      "type": "text",
      "id": "login_text",
      "label": "Admin login text",
      "default": "Вхід для адміністратора"
    },
    {
      "type": "header",
      "content": "Visual Elements"
    },
    {
      "type": "checkbox",
      "id": "show_motor_image",
      "label": "Show motor image",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "motor_image",
      "label": "Motor image"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "Show social media links",
      "default": true
    },
    {
      "type": "link_list",
      "id": "social_links",
      "label": "Social media menu"
    }
  ],
  "presets": [
    {
      "name": "Password Page",
      "category": "Password"
    }
  ]
}
{% endschema %}
