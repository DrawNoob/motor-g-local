<!-- Our Motors Section -->
<section class="z-10 responsive-padding bg-white xl:pt-[80px] md:pt-[65px] pt-[50px] lg:pb-[70px] pb-[50px]">
  <div class="max-w-[1440px] mx-auto flex flex-col">
    <div class="grid grid-cols-1 gap-7 p-3 md:p-6 lg:grid-cols-6 lg:items-start lg:gap-4">
      <div class="flex w-full flex-col lg:col-span-3">
        <div class="grid w-full grid-cols-3 gap-2">
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-1.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-2.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-3.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-4.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-5.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-6.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
        </div>
        <div class="mt-3 border-t border-[#8d8d8d] pt-2 text-center text-[22px] leading-[1.2] text-[#151515] md:pt-3 md:text-[28px]">
          {{ section.settings.fpv_title }}
        </div>
      </div>

      <div class="flex w-full flex-col lg:col-span-2">
        <div class="grid w-full grid-cols-2 gap-2">
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-7.png' | asset_url }}" alt="{{ section.settings.fixed_wing_title | escape }}">
          </div>
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-8.png' | asset_url }}" alt="{{ section.settings.fixed_wing_title | escape }}">
          </div>
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-9.png' | asset_url }}" alt="{{ section.settings.fixed_wing_title | escape }}">
          </div>
        </div>
        <div class="mt-3 border-t border-[#8d8d8d] pt-2 text-center text-[22px] leading-[1.2] text-[#151515] md:pt-3 md:text-[28px]">
          {{ section.settings.fixed_wing_title }}
        </div>
      </div>

      <div class="mx-auto flex w-full max-w-[248px] flex-col lg:col-span-1 lg:mx-0 lg:max-w-none">
        <div class="grid w-full grid-cols-1 gap-2">
          <div class="aspect-square overflow-hidden">
            <img class="h-full w-full object-cover" src="{{ 'new-mt-10.png' | asset_url }}" alt="{{ section.settings.vandal_title | escape }}">
          </div>
        </div>
        <div class="mt-3 border-t border-[#8d8d8d] pt-2 text-center text-[22px] leading-[1.2] text-[#151515] md:pt-3 md:text-[36px] lg:text-[28px]">
          {{ section.settings.vandal_title }}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Our Motors Section",
  "settings": [
    {
      "type": "text",
      "id": "fpv_title",
      "label": "FPV title",
      "default": "FPV"
    },
    {
      "type": "text",
      "id": "fixed_wing_title",
      "label": "Fixed-Wing title",
      "default": "Fixed-Wing"
    },
    {
      "type": "text",
      "id": "vandal_title",
      "label": "Vandal title",
      "default": "Vandal (Interceptors)"
    }
  ],
  "presets": [
    {
      "name": "Our Motors Section"
    }
  ]
}
{% endschema %}
