<!-- Our Motors Section -->
<section class="z-10 responsive-padding xl:pt-[80px] md:pt-[65px] pt-[50px] lg:pb-[70px] pb-[50px]">
  <div class="max-w-[1440px] mx-auto flex flex-col">
    <p class="motors-all-models">{{ section.settings.all_models_text }}</p>

    <div class="motors-wrap">
      <div class="motor-group motor-group--fpv">
        <div class="motor-grid motor-grid--6">
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-1.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-2.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-3.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-4.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-5.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-6.png' | asset_url }}" alt="{{ section.settings.fpv_title | escape }}">
          </div>
        </div>
        <div class="motor-group-label">{{ section.settings.fpv_title }}</div>
      </div>

      <div class="motor-group motor-group--fixed">
        <div class="motor-grid motor-grid--3">
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-7.png' | asset_url }}" alt="{{ section.settings.fixed_wing_title | escape }}">
          </div>
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-8.png' | asset_url }}" alt="{{ section.settings.fixed_wing_title | escape }}">
          </div>
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-9.png' | asset_url }}" alt="{{ section.settings.fixed_wing_title | escape }}">
          </div>
        </div>
        <div class="motor-group-label">{{ section.settings.fixed_wing_title }}</div>
      </div>

      <div class="motor-group motor-group--vandal">
        <div class="motor-grid motor-grid--1">
          <!-- Item -->
          <div class="motor-card">
            <img src="{{ 'new-mt-10.png' | asset_url }}" alt="{{ section.settings.vandal_title | escape }}">
          </div>
        </div>
        <div class="motor-group-label">{{ section.settings.vandal_title }}</div>
      </div>
    </div>
  </div>
</section>

<style>
  .motors-all-models {
    margin: 0 0 16px;
    color: #7b7b7b;
    font-size: 16px;
    line-height: 1.2;
  }

  .motors-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: 16px;
    padding: 24px 16px 20px;
    background: #ececec;
  }

  .motor-group {
    display: flex;
    flex-direction: column;
  }

  .motor-grid {
    display: grid;
    gap: 8px;
  }

  .motor-grid--6 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    width: 560px;
  }

  .motor-grid--3 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    width: 272px;
  }

  .motor-grid--1 {
    grid-template-columns: 1fr;
    width: 128px;
  }

  .motor-card {
    aspect-ratio: 1 / 1;
    border-radius: 10px;
    overflow: hidden;
    background: #dcdcdc;
  }

  .motor-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .motor-group-label {
    position: relative;
    margin-top: 16px;
    padding-top: 14px;
    text-align: center;
    color: #151515;
    font-size: 28px;
    line-height: 1.2;
  }

  .motor-group-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    border-top: 1px solid #7b7b7b;
  }

  @media (max-width: 1024px) {
    .motors-all-models {
      font-size: 14px;
      margin-bottom: 12px;
    }

    .motors-wrap {
      gap: 26px;
      padding: 20px 12px;
    }

    .motor-group {
      width: 100%;
    }

    .motor-grid--6,
    .motor-grid--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      width: 100%;
    }

    .motor-grid--1 {
      width: 33.3333%;
      min-width: 112px;
      margin: 0 auto;
    }

    .motor-group-label {
      font-size: 26px;
      margin-top: 12px;
      padding-top: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Our Motors Section",
  "settings": [
    {
      "type": "text",
      "id": "all_models_text",
      "label": "All models text",
      "default": "All models"
    },
    {
      "type": "text",
      "id": "fpv_title",
      "label": "FPV title",
      "default": "FPV"
    },
    {
      "type": "text",
      "id": "fixed_wing_title",
      "label": "Fixed-Wing title",
      "default": "Fixed-Wing"
    },
    {
      "type": "text",
      "id": "vandal_title",
      "label": "Vandal title",
      "default": "Vandal (Interceptors)"
    }
  ],
  "presets": [
    {
      "name": "Our Motors Section",
      "category": "Main Page"
    }
  ]
}
{% endschema %}
