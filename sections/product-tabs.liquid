<!-- TAB Section -->
<section class="flex flex-col md:py-[70px] py-[50px] bg-white">
  <!-- Tabs Desktop & Mobile -->
  <div class="md:flex hidden w-full justify-center gap-10">
    <button id="tab-info-btn" class="tab-btn text-2xl cursor-pointer font-neue-m text-main-blue border-b-2 border-main-blue">{{ 'sections.custom.more-details' | t }}</button>
    <button id="tab-uses-btn" class="tab-btn text-2xl cursor-pointer font-neue-m text-main-gray hover:text-main-blue border-b-2 border-transparent hover:border-main-blue duration-150">
      {{ 'sections.custom.popular-use' | t }}
    </button>
  </div>
  <!-- Custom Select -->
  <div class="md:hidden px-4 mt-4 w-full relative flex items-center">
    <button
      id="tab-select-toggle"
      class="w-full text-white bg-main-blue font-neue-m py-3 px-4 underline text-lg appearance-none flex justify-between items-center"
    >
      <span id="tab-select-current">{{ 'sections.custom.more-details' | t }}</span>
      <img class="absolute z-0 right-10 pointer-events-none" src="{{ 'chaika.svg' | asset_url }}" alt="Arr">
    </button>

    <!-- Modal -->
    <div
      id="tab-select-options"
      class="absolute top-full left-0 mt-1 hidden px-4 w-full z-50"
    >
      <div class="bg-white border shadow-lg w-full">
        <div class="tab-option px-4 py-2 text-black" data-value="info">
          {{ 'sections.custom.more-details' | t }}
        </div>
        <div class="tab-option px-4 py-2 text-black" data-value="uses">
          {{ 'sections.custom.popular-use' | t }}
        </div>
      </div>
    </div>
  </div>

  <!-- Tab Content - 1 -->
  <div id="tab-info" class="flex flex-col max-w-[1440px] mx-auto xl:gap-10 gap-5 w-full">
    <div class="w-full grid grid-cols-1 md:grid-cols-2 xl:gap-10 gap-5 mt-10 responsive-padding">
      <div class="w-full relative">
        <img class="md:block hidden w-full md:h-[520px] h-[450px] object-cover object-left" src="{{ '1.webp' | asset_url }}" alt="Image">
        <img class="md:hidden w-full" src="{{ '1-mob.webp' | asset_url }}" alt="Image">
      </div>
      <div class="w-full relative">
        <img class="md:block hidden w-full md:h-[520px] h-[450px] object-cover object-left" src="{{ '2.webp' | asset_url }}" alt="Image">
        <img class="md:hidden w-full" src="{{ '2-mob.webp' | asset_url }}" alt="Image">
      </div>
    </div>

    <div class="relative w-full px-0 lg:px-8 xl:px-14 flex flex-col items-center">
      <img class="md:block hidden w-full" src="{{ '3.webp' | asset_url }}" alt="Image">
      <img class="md:hidden w-full" src="{{ '3-mob.webp' | asset_url }}" alt="Image">
    </div>
  </div>

  <!-- Tab Content - 2 -->
  <div id="tab-uses" class="hidden flex-col items-start max-w-[1440px] mx-auto w-full px-0 md:px-6 lg:px-8 xl:px-14">
    <h3 class="responsive-text font-neue-m py-10 md:px-0 px-4">{{ product.title }}</h3>
    <div class="w-full overflow-x-auto md:px-0 px-4">
      <div class="min-w-[750px] md:min-w-full flex flex-col p-[30px] rounded-2xl bg-background">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-main-gray font-neue-b">
              <th class="py-2">{{ section.settings.heading_propeller }}</th>
              <th class="py-2">{{ section.settings.heading_6s }}</th>
              <th class="py-2">{{ section.settings.heading_8s }}</th>
              <th class="py-2">{{ section.settings.heading_12s }}</th>
            </tr>
          </thead>

          <tbody>
            {% for block in section.blocks %}
              {% if block.type == 'table_row' %}
                <tr class="border-b align-top border-main-gray font-neue-r">
                  <td class="py-3">
                    {{ block.settings.propeller -}}
                    <br>
                    <span class="block text-sm">{{ block.settings.note_1 }}</span>
                    <span class="block text-sm">{{ block.settings.note_2 }}</span>
                  </td>
                  <td class="py-3">{{ block.settings.kv6s }}</td>
                  <td class="py-3">{{ block.settings.kv8s }}</td>
                  <td class="py-3">{{ block.settings.kv12s }}</td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- Tab Functionallity -->
<script>
  const tabs = {
    info: {
      btn: document.getElementById('tab-info-btn'),
      content: document.getElementById('tab-info'),
    },
    uses: {
      btn: document.getElementById('tab-uses-btn'),
      content: document.getElementById('tab-uses'),
    },
  };

  const selectToggle = document.getElementById('tab-select-toggle');
  const selectOptions = document.getElementById('tab-select-options');
  const selectCurrent = document.getElementById('tab-select-current');
  const mobileOptions = selectOptions.querySelectorAll('.tab-option');

  function activateTab(activeKey) {
    for (const key in tabs) {
      const { btn, content } = tabs[key];
      const isActive = key === activeKey;

      if (btn) {
        btn.classList.toggle('text-main-blue', isActive);
        btn.classList.toggle('border-main-blue', isActive);
        btn.classList.toggle('text-main-gray', !isActive);
        btn.classList.toggle('border-transparent', !isActive);
      }

      content.classList.toggle('flex', isActive);
      content.classList.toggle('hidden', !isActive);
    }

    if (activeKey === 'info') {
      selectCurrent.textContent = tabs.info.btn.textContent.trim();
    } else {
      selectCurrent.textContent = tabs.uses.btn.textContent.trim();
    }

    selectOptions.classList.add('hidden');
  }

  tabs.info.btn.addEventListener('click', () => activateTab('info'));
  tabs.uses.btn.addEventListener('click', () => activateTab('uses'));

  selectToggle.addEventListener('click', () => {
    selectOptions.classList.toggle('hidden');
  });

  mobileOptions.forEach((option) => {
    option.addEventListener('click', () => {
      const value = option.getAttribute('data-value');
      activateTab(value);
    });
  });

  document.addEventListener('click', (e) => {
    if (!selectToggle.contains(e.target) && !selectOptions.contains(e.target)) {
      selectOptions.classList.add('hidden');
    }
  });
</script>

{% schema %}
{
  "name": "Table Section",
  "settings": [
    {
      "type": "text",
      "id": "heading_propeller",
      "label": "Заголовок: Пропелер",
      "default": "Пропелер"
    },
    {
      "type": "text",
      "id": "heading_6s",
      "label": "Заголовок: Акумулятор 6S",
      "default": "Акумулятор 6S"
    },
    {
      "type": "text",
      "id": "heading_8s",
      "label": "Заголовок: Акумулятор 8S",
      "default": "Акумулятор 8S"
    },
    {
      "type": "text",
      "id": "heading_12s",
      "label": "Заголовок: Акумулятор 12S",
      "default": "Акумулятор 12S"
    }
  ],
  "blocks": [
    {
      "type": "table_row",
      "name": "Рядок таблиці",
      "settings": [
        {
          "type": "text",
          "id": "propeller",
          "label": "Назва пропелера",
          "default": "APC 7x11x2"
        },
        {
          "type": "text",
          "id": "note_1",
          "label": "Примітка 1",
          "default": "Вага дрона: 1–3 кг"
        },
        {
          "type": "text",
          "id": "note_2",
          "label": "Примітка 2",
          "default": "Швидкість: ДО 160 км/год"
        },
        {
          "type": "text",
          "id": "kv6s",
          "label": "Значення KV для 6S",
          "default": "1300KV"
        },
        {
          "type": "text",
          "id": "kv8s",
          "label": "Значення KV для 8S",
          "default": "900KV"
        },
        {
          "type": "text",
          "id": "kv12s",
          "label": "Значення KV для 12S",
          "default": "650KV"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Table Section"
    }
  ]
}
{% endschema %}
