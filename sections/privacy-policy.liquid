<div class="flex flex-col max-w-[1400px] mx-auto px-4 md:py-20 py-10">
  <h1 class="text-center xl:text-5xl md:text-3xl text-2xl">{{ section.settings.title }}</h1>
  <p class="mt-10 leading-[150%]">
    {{ section.settings.policy }}
  </p>
</div>

{% schema %}
{
  "name": "Privacy Policy",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Policy Title",
      "default": "Політика конфіденційності"
    },
    {
      "type": "richtext",
      "id": "policy",
      "label": "Policy Content"
    }
  ]
}
{% endschema %}
