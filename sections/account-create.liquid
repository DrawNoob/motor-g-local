<div class="flex justify-center items-center w-full md:py-28 py-16">
  <div class="flex flex-col bg-background rounded-2xl w-full md:max-w-[600px] max-w-[92%] md:px-10 px-5 md:py-16 py-6">
    <h1 class="md:text-center text-left font-emilio md:text-4xl text-2xl">{{ section.settings.heading }}</h1>
    <form class="md:mt-10 mt-4" action="POST">
      <input
        class="w-full border-b-[1px] border-gray-500 py-4 focus:pl-4"
        type="text"
        placeholder="{{ section.settings.first_name_placeholder }}"
      >
      <input
        class="w-full border-b-[1px] border-gray-500 py-4 mt-3 focus:pl-4"
        type="text"
        placeholder="{{ section.settings.last_name_placeholder }}"
      >
      <input
        class="w-full border-b-[1px] border-gray-500 py-4 mt-3 focus:pl-4"
        type="text"
        placeholder="{{ section.settings.email_placeholder }}"
      >
      <input
        class="w-full border-b-[1px] border-gray-500 py-4 mt-3 focus:pl-4"
        type="password"
        placeholder="{{ section.settings.password_placeholder }}"
      >
      <button class="mt-7 bg-button rounded-xl w-full py-6">{{ section.settings.submit_text }}</button>
    </form>
  </div>
</div>

{% schema %}
{
  "name": "Create Account Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create account"
    },
    {
      "type": "header",
      "content": "Placeholders"
    },
    {
      "type": "text",
      "id": "first_name_placeholder",
      "label": "First Name Placeholder",
      "default": "First Name"
    },
    {
      "type": "text",
      "id": "last_name_placeholder",
      "label": "Last Name Placeholder",
      "default": "Last Name"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Placeholder",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "password_placeholder",
      "label": "Password Placeholder",
      "default": "Password"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "submit_text",
      "label": "Create Button Text",
      "default": "Create"
    }
  ]
}
{% endschema %}
